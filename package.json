{
  "name": "phishy-email-analyzer",
  "version": "3.0.0",
  "description": "AI-powered phishing email analysis tool using Claude to evaluate suspicious emails",
  "main": "index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "phishy-try": "dist/cli/try.js"
  },
  "scripts": {
    "try": "npm run build && node dist/cli/try.js",
    "build": "tsc",
    "build:watch": "tsc --watch",
    "clean": "rm -rf dist",
    "prebuild": "npm run clean",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "deploy": "npm run build && zip -r function.zip dist node_modules package.json index.js && aws lambda update-function-code --function-name phishyAWS --zip-file fileb://function.zip",
    "deploy:legacy": "zip -r function.zip index.js node_modules package.json && aws lambda update-function-code --function-name phishy --zip-file fileb://function.zip"
  },
  "keywords": [
    "security",
    "phishing",
    "email",
    "analysis",
    "claude",
    "aws",
    "lambda",
    "bedrock",
    "enterprise"
  ],
  "author": "Colin Stoner <colinstoner@gmail.com>",
  "license": "Apache-2.0",
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.1077.0",
    "@aws-sdk/client-rds-data": "^3.1077.0",
    "@aws-sdk/client-s3": "^3.1077.0",
    "@aws-sdk/client-secrets-manager": "^3.1077.0",
    "@aws-sdk/client-ses": "^3.1077.0",
    "axios": "^1.18.1",
    "mailparser": "^3.9.12",
    "pg": "^8.22.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@smithy/util-stream": "^4.7.4",
    "@types/aws-lambda": "^8.10.162",
    "@types/jest": "^30.0.0",
    "@types/mailparser": "^3.4.6",
    "@types/node": "^26.0.1",
    "@types/pg": "^8.20.0",
    "@typescript-eslint/eslint-plugin": "^8.62.1",
    "@typescript-eslint/parser": "^8.62.1",
    "aws-sdk-client-mock": "^4.1.0",
    "aws-sdk-client-mock-jest": "^4.1.0",
    "esbuild": "^0.28.1",
    "eslint": "^10.6.0",
    "jest": "^30.4.2",
    "prettier": "^3.9.4",
    "ts-jest": "^29.4.11",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1"
  },
  "overrides": {
    "js-yaml": "^3.15.0"
  },
  "engines": {
    "node": ">=22.0.0 <23.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/colinstoner/phishy-email-analyzer.git"
  },
  "bugs": {
    "url": "https://github.com/colinstoner/phishy-email-analyzer/issues"
  },
  "homepage": "https://github.com/colinstoner/phishy-email-analyzer#readme"
}
